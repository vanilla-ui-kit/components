  "scripts": {
    "build": "node tools/build.js",
    "build:min": "node tools/minify.js",
    "size": "node tools/size-check.js",
    "test": "node --test test/*.test.js",
    "test:browser": "node tools/browser-test.js"
  },
  "sideEffects": true,
  "keywords": [
    "vanillakit",
    "vanilla",
    "components",
    "datepicker",
    "toast",
    "zero-dependency",
    "headless",
    "dark-mode"
