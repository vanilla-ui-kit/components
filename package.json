  "files": [
    "types",
    "core",
    "datepicker",
    "toast",
    "tooltip",
    "menu",
    "modal",
    "tabs",
    "select",
    "command",
    "form",
    "phone",
    "drawer",
    "segmented",
    "progress",
    "popconfirm",
    "rating",
    "autocomplete",
    "upload",
    "slider",
    "number",
    "pagination",
    "empty",
    "dist"
