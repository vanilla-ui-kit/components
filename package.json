{
  "name": "broadside",
  "version": "1.0.0",
  "description": "Single-file, zero-dependency UI components for vanilla JavaScript — beautiful by default, headless when you want, usable together or standalone.",
  "main": "dist/broadside.js",
  "exports": {
    ".": "./dist/broadside.js",
    "./core": "./core/core.js",
    "./datepicker": "./datepicker/datepicker.js",
    "./toast": "./toast/toast.js",
    "./datepicker.css": "./dist/datepicker.css",
    "./toast.css": "./dist/toast.css",
    "./broadside.css": "./dist/broadside.css",
    "./package.json": "./package.json"
  },
  "files": [
    "core",
    "datepicker",
    "toast",
    "dist"
  ],
  "scripts": {
    "build": "node tools/build.js"
  },
  "sideEffects": true,
  "keywords": [
    "broadside",
    "vanilla",
    "components",
    "datepicker",
    "toast",
    "zero-dependency",
    "headless",
    "dark-mode"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/abdallahk/vanilla-components.git"
  },
  "license": "MIT"
}
